# CompIntel Research 环境变量模板
#
# 使用方式：
# 1. 复制本文件为 .env
# 2. 将占位 key 替换为真实 key
# 3. 不要提交 .env（已被 .gitignore 忽略）
#
# 设计原则：
# - LLM 统一使用 LLM_* 字段，通过 LLM_PROVIDER 切换服务商
# - 搜索统一使用 SERPAPI_API_KEY 字段，通过 SEARCH_PROVIDER 切换服务商
# - 当前默认启用 DeepSeek + Tavily，其它常用服务商保留中文注释占位

# ---------------------------------------------------------------------------
# LLM 配置
# 支持的 LLM_PROVIDER：deepseek、kimi、glm、openai-compatible
# ---------------------------------------------------------------------------

# DeepSeek（默认启用）
# 获取 API Key：https://platform.deepseek.com/
LLM_PROVIDER=deepseek
LLM_API_KEY=replace-with-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
FAST_LLM=deepseek-chat
SMART_LLM=deepseek-chat
STRATEGIC_LLM=deepseek-reasoner
# 单次 LLM 请求超时时间（秒）。超时后框架会使用已有证据生成非占位降级结果。
LLM_TIMEOUT_SECONDS=60
# 本地 embedding 模型（空 = 使用轻量 HashEmbedder；填写则加载 sentence-transformers 模型）
# 推荐: BAAI/bge-small-zh（中文+英文，512 维，~100 MB，CPU 友好）
# 留空禁用: EMBEDDING_MODEL=
EMBEDDING_MODEL=BAAI/bge-small-zh
# HuggingFace 模型缓存目录（默认 ~/.cache/huggingface）。建议设到有足够空间的盘。
HF_HOME=D:/huggingface

# Kimi / Moonshot（需要时取消注释，并注释掉上面的 DeepSeek 配置）
# 获取 API Key：https://platform.moonshot.cn/
# LLM_PROVIDER=kimi
# LLM_API_KEY=replace-with-your-kimi-api-key
# LLM_BASE_URL=https://api.moonshot.cn/v1
# FAST_LLM=moonshot-v1-8k
# SMART_LLM=moonshot-v1-32k
# STRATEGIC_LLM=moonshot-v1-128k

# GLM / 智谱 AI（需要时取消注释，并注释掉上面的 DeepSeek 配置）
# 获取 API Key：https://open.bigmodel.cn/
# LLM_PROVIDER=glm
# LLM_API_KEY=replace-with-your-glm-api-key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# FAST_LLM=glm-4-flash
# SMART_LLM=glm-4-plus
# STRATEGIC_LLM=glm-4-plus

# OpenAI-compatible 自定义服务（需要时取消注释）
# LLM_PROVIDER=openai-compatible
# LLM_API_KEY=replace-with-your-compatible-api-key
# LLM_BASE_URL=https://your-compatible-endpoint/v1
# FAST_LLM=your-fast-model
# SMART_LLM=your-smart-model
# STRATEGIC_LLM=your-strategic-model

# ---------------------------------------------------------------------------
# 搜索 API 配置
# 支持的 SEARCH_PROVIDER：tavily、serpapi
# 统一密钥字段：SERPAPI_API_KEY
# ---------------------------------------------------------------------------

# Tavily 搜索（推荐）- 获取 API 密钥：https://tavily.com/
SEARCH_PROVIDER=tavily
SERPAPI_API_KEY=tvly-your_tavily_key_here

# SerpApi 搜索（备用）- 获取 API 密钥：https://serpapi.com/
# SEARCH_PROVIDER=serpapi
# SERPAPI_API_KEY=your_serpapi_key_here

# ---------------------------------------------------------------------------
# 运行产物配置
# ---------------------------------------------------------------------------

COMPINTEL_AUDIT_PATH=outputs/compintel_audit.jsonl
